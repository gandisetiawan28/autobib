# AutoBib Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Security - Generate a strong random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ENCRYPTION_KEY=your-32-char-encryption-key-here!!

# Mendeley OAuth App Credentials
# Register at: https://dev.mendeley.com
MENDELEY_CLIENT_ID=23763
MENDELEY_CLIENT_SECRET=JAyUHZCTXcAcc5V2
MENDELEY_REDIRECT_URI=http://localhost:3001/auth/mendeley/callback

# Frontend URL (for CORS)
FRONTEND_URL=https://localhost:3000

# Database
DB_PATH=./database/autobib.db

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/autobib.log
